# ─── GRAK Hotel — Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env to Git.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# Use Gmail App Password: https://myaccount.google.com/apppasswords
# Or use any SMTP provider (Brevo / Mailgun / SendGrid free tier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# ── Hotel Admin Email ──────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@grakhotel.com

# ── CORS (set to your live domain once deployed) ───────────────────────────────
# Example: https://www.grakhotel.com
ALLOWED_ORIGIN=*
